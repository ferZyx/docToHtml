{
  "name": "doc-to-html",
  "version": "1.1.0",
  "description": "Convert .doc/.docx files to HTML using LibreOffice + Pandoc",
  "main": "./wordToHtmlConverter.js",
  "types": "./wordToHtmlConverter.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./wordToHtmlConverter.d.ts",
      "import": "./wordToHtmlConverter.js",
      "default": "./wordToHtmlConverter.js"
    }
  },
  "bin": {
    "doc-to-html": "./cli.js"
  },
  "files": [
    "cli.js",
    "wordToHtmlConverter.js",
    "wordToHtmlMammoth.js",
    "wordToHtmlConverter.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test cli.test.js && node -e \"import('./wordToHtmlConverter.js').then(()=>console.log('ok'))\"",
    "test:integration": "node test.js"
  },
  "keywords": [
    "doc",
    "docx",
    "html",
    "pandoc",
    "libreoffice"
  ],
  "author": "ferZyx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferZyx/docToHtml.git"
  },
  "bugs": {
    "url": "https://github.com/ferZyx/docToHtml/issues"
  },
  "homepage": "https://github.com/ferZyx/docToHtml#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.12.2"
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "sanitize-html": "^2.17.0"
  }
}
